# Delta config layered on top of busybox `make defconfig`.
# Only two things we actually care about:
#   1. static link so the initramfs needs no libc / ld.so
#   2. drop networking/tls-heavy applets we don't use
#
# Apply via: scripts/kconfig/merge_config.sh -m .config busybox.config

CONFIG_STATIC=y

# Drop TLS/crypto bloat we don't need for the hello-world smoke test.
# CONFIG_TLS is not set
# CONFIG_FEATURE_WGET_HTTPS is not set
